# pispot dashboard environment — example
# After running `make init`, a .env file is generated here automatically.
# You can also copy this file to .env and fill in values manually.
#
# docker-compose.yml reads .env from this directory when running on the Pi.
# These values are NOT used during Mac builds — the Makefile injects them
# directly when shipping the compose file over SSH.

# Pi SSH target (hostname or IP).
PI_HOST=your-pi.local

# TLS certificate name (prefix of .crt / .key / .ca files under ssl/).
PISPOT_TLS_CERT_NAME=your_cert_name

# Dashboard page title shown in the browser tab and header.
DASHBOARD_TITLE=pispot
